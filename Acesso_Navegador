import importlib.util
import shutil

bdgd_2023 = (r"C:\TCC_V02\BDGD_2023")
bdgd_2024 = (r"C:\TCC_V02\BDGD_2024")

def import_module_from_path(name: str, path: Path):
    path = Path(path)
    spec = importlib.util.spec_from_file_location(name, str(path))
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod

# Abrir navegador #
def abrir_navegador(destino_pasta):
    options = webdriver.EdgeOptions()
    prefs = {"download.default_directory": str(destino_pasta), "safebrowsing.enabled": True}
    options.add_experimental_option("prefs", prefs)
    options.add_argument("--start-maximized")
    return webdriver.Edge(options=options)

# Aguardar download #
def aguardar_download_concluir(destino_pasta, limite=600):
    pasta = Path(destino_pasta)
    start = time.time()

    while time.time() - start < limite:
        zipfiles = list(pasta.glob("*.zip"))
        if zipfiles:
            zipfile_final = max(zipfiles, key=lambda f: f.stat().st_mtime)
            cr = pasta / (zipfile_final.name + ".crdownload")
            if not cr.exists():
                return zipfile_final
        time.sleep(2)
    return None

# Baixar BDGD #
def download_bdgd(destino_pasta, ano):
    destino = Path(destino_pasta)
    destino.mkdir(exist_ok=True)

    # Remover ZIPs na pasta
    for ant in destino.glob("Cemig-D*.zip"):
        try:
            ant.unlink()
        except:
            pass
    driver = abrir_navegador(destino_pasta)

    try:
        print(f"Acessar site da ANEEL")
        driver.get("https://dadosabertos.aneel.gov.br/dataset/base-de-dados-geografica-da-distribuidora-bdgd")

        WebDriverWait(driver, 20).until(
            EC.element_to_be_clickable((By.LINK_TEXT, "Explorar"))
        ).click()

        time.sleep(2)
        WebDriverWait(driver, 20).until(
            EC.element_to_be_clickable((By.LINK_TEXT, "Ir para recurso"))
        ).click()

        print(f"Pesquise por CEMIG ano {ano} ")
        input("eNTER quando iniciar iniciar download ")

        arquivo = aguardar_download_concluir(destino)

        if arquivo:
            print("Extrair arquivo zip")
            extrair_zip(arquivo, destino)

    except Exception as e:
        print("Erro:", e)
        driver.quit()

# Extrair arquivo zip #
def extrair_zip(zip_path, destino):
    zip_path = Path(zip_path)

    caminho_2023 = Path(r"C:\TCC_Ana\Arquivos_ANA")
    caminho_2024 = Path(r"C:\TCC_Ana\2023")

    # Caminho final #
    if str(destino) == str(caminho_2023):
        destino_final = caminho_2023
    elif str(destino) == str(caminho_2024):
        destino_final = caminho_2024
    else:
        destino_final = Path(destino) 

    with zipfile.ZipFile(zip_path, 'r') as z:
        gdb_folders = [x.split("/")[0] for x in z.namelist() if x.endswith(".gdb/")]

        if gdb_folders:
            folder_name = gdb_folders[0]
            pasta_antiga = destino_final / folder_name

            if pasta_antiga.exists():
                shutil.rmtree(pasta_antiga)
        z.extractall(destino_final)
    print(f"Arquivo extraído")

